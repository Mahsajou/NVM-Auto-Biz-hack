# Nevermined — SUBSCRIBER key (not builder key)
NVM_API_KEY=sandbox:your-subscriber-api-key
NVM_ENVIRONMENT=sandbox
NVM_PLAN_ID=seller-plan-id       # The seller's plan you subscribed to
NVM_AGENT_ID=seller-agent-id     # Optional: seller's agent ID

# Seller endpoint
SELLER_URL=http://localhost:3000

# LLM - OpenAI (for local dev with agent.py)
OPENAI_API_KEY=sk-your-key
MODEL_ID=gpt-4o-mini

# LLM - Bedrock (for AgentCore with agent_agentcore.py)
# AWS_REGION=us-west-2
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# Seller A2A endpoint (for A2A mode)
SELLER_A2A_URL=http://localhost:9000

# Buyer API server port (backend only, no UI). Frontend on 5173 proxies /api here.
BUYER_PORT=8000

# Budget limits (optional, 0 = unlimited)
MAX_DAILY_SPEND=100
MAX_PER_REQUEST=10

# Trust Net (rank/verify sellers - USDC plan for list_agents, get_reviews, submit_review)
TRUST_NET_PLAN_ID=111171385715053379363820285370903002263619322296632596378198131296828952605172

# Platon (persistent context - memory.retrieve_context, memory.dump_session)
# Subscribe at https://platon.bigf.me/ — use your NVM_API_KEY to get x402 tokens.
PLATON_PLAN_ID=73169765125098902371333949161624114039157379307050553178571193711771922123338
PLATON_AGENT_ID=19346478288243105495031065907200687372039626635874134001440870868803651261845

# Shop Mate Seller Reviews (your reviews seller - sells review data)
REVIEWS_SELLER_URL=https://shopmate-seller-reviews
REVIEWS_ENDPOINT_PATH=/data
REVIEWS_PLAN_ID=67475140880333701491089781943430116921269732275997393271096692356851482067458
REVIEWS_AGENT_ID=105770377365895420516068789314715951313306586166892856219570381354903905486817

# Prompta (marketing/lead generation - find customers with grocery shopping needs)
# Leave empty to auto-fetch agent endpoint from Nevermined API
PROMPTA_SELLER_URL=
# Endpoint path if Prompta uses /ask instead of /data (some agents use /ask)
PROMPTA_ENDPOINT_PATH=/data
PROMPTA_PLAN_ID=75487548881585806765891238817506375815024719766032068317736664462463369221318
PROMPTA_AGENT_ID=28744455506253719439355309070854035710561167109692836172020876792102066260600

# Apify (for ecommerce availability check - "Check if Amazon carry it")
APIFY_API_KEY=your-apify-api-token
# Actor: apify/e-commerce-scraping-tool (default). Override if needed:
# APIFY_ACTOR_ID=apify/e-commerce-scraping-tool

# AgentCore deployment (for web-agentcore mode)
# PORT=8080                                   # Set by AgentCore runtime
# AGENT_URL=https://your-agent.agentcore.aws  # AgentCore public URL
# SELLER_AGENT_ARN=arn:aws:bedrock-agentcore:us-west-2:ACCOUNT:runtime/seller_agent-XXX
